# Admin account used for the first sign-in
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password

# JWT signing secret used for access tokens (use a long random value in production)
JWT_SECRET=replace-with-a-long-random-jwt-secret

# Provider API key encryption secret used at rest by the backend
ENCRYPTION_KEY=replace-with-a-long-random-encryption-secret

# Allowed browser origins for direct frontend-to-backend development
# Use a comma-separated list when you need multiple origins.
CORS_ALLOWED_ORIGINS=http://localhost:5170,http://127.0.0.1:5170
